{
  "name": "react-native-markdown",
  "version": "0.1.0",
  "description": "High-performance native Markdown renderer and editor for React Native",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/commonjs/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "cpp",
    "ios",
    "android",
    "react-native-markdown.podspec",
    "react-native.config.js",
    "app.plugin.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "example": "bun --cwd example"
  },
  "keywords": [
    "react-native",
    "markdown",
    "editor",
    "renderer",
    "gfm",
    "fabric",
    "new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alizahid/react-native-markdown"
  },
  "author": "Ali Zahid <ali.zahid@live.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alizahid/react-native-markdown/issues"
  },
  "homepage": "https://github.com/alizahid/react-native-markdown#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@expo/config-plugins": "~55.0.8",
    "@types/react": "~19.0.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.0.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-builder-bob": "^0.41.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0"
  },
  "peerDependenciesMeta": {
    "@expo/config-plugins": {
      "optional": true
    }
  },
  "codegenConfig": {
    "name": "MarkdownViewSpec",
    "type": "components",
    "jsSrcsDir": "src"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
