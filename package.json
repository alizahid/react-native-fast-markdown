{
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@react-native/babel-preset": "0.86.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "del-cli": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "release-it": "^20.2.1",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3",
    "ultracite": "7.8.4"
  },
  "name": "react-native-fast-markdown",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "scripts": {
    "example": "bun run --cwd example",
    "clean": "del-cli lib",
    "test": "bun test src && cpp/tests/run_tests.sh",
    "prepare": "husky",
    "typecheck": "tsc",
    "release": "release-it --only-version",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "version": "0.1.0",
  "workspaces": [
    "example"
  ],
  "description": "Fast Markdown viewer/editor for React Native",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-fast-markdown-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alizahid/react-native-fast-markdown.git"
  },
  "author": "Ali Zahid <ali.zahid@live.com> (https://github.com/alizahid)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alizahid/react-native-fast-markdown/issues"
  },
  "homepage": "https://github.com/alizahid/react-native-fast-markdown#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "bun@1.3.14",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "FastMarkdownViewSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.fastmarkdown"
    },
    "ios": {
      "components": {
        "FastMarkdownView": {
          "className": "FastMarkdownView"
        }
      }
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "fabric-view",
    "languages": "kotlin-objc",
    "tools": [
      "release-it"
    ],
    "version": "0.63.0"
  }
}
