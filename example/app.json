{
  "expo": {
    "name": "FastMarkdown Example",
    "slug": "react-native-fast-markdown-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fastmarkdown.example"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "fastmarkdown.example"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-header-collision-canary.js",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Satoshi",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Satoshi-Regular.otf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Satoshi-Italic.otf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Satoshi-Bold.otf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Satoshi-BoldItalic.otf",
                    "weight": 700,
                    "style": "italic"
                  }
                ]
              },
              {
                "fontFamily": "Zodiak",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Zodiak-Regular.otf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Zodiak-Italic.otf",
                    "weight": 400,
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Zodiak-Bold.otf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Zodiak-BoldItalic.otf",
                    "weight": 700,
                    "style": "italic"
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Satoshi-Regular.otf",
              "./assets/fonts/Satoshi-Italic.otf",
              "./assets/fonts/Satoshi-Bold.otf",
              "./assets/fonts/Satoshi-BoldItalic.otf",
              "./assets/fonts/Zodiak-Regular.otf",
              "./assets/fonts/Zodiak-Italic.otf",
              "./assets/fonts/Zodiak-Bold.otf",
              "./assets/fonts/Zodiak-BoldItalic.otf"
            ]
          }
        }
      ]
    ]
  }
}
