{
  "name": "react-native-fast-markdown-example",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "build:android": "cd android && ./gradlew assembleDebug -DtestBuildType=debug -Dorg.gradle.jvmargs=-Xmx4g",
    "build:ios": "xcodebuild ONLY_ACTIVE_ARCH=YES -workspace ios/FastMarkdownExample.xcworkspace -UseNewBuildSystem=YES -scheme FastMarkdownExample -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build -quiet",
    "build:web": "expo export --platform web",
    "ios": "expo run:ios",
    "start": "expo start --dev-client",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.2",
    "@shopify/flash-list": "2.0.2",
    "expo": "~57.0.1",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "babel-preset-expo": "^57.0.1",
    "expo-dev-client": "~57.0.4",
    "react-native-builder-bob": "^0.43.0",
    "react-native-monorepo-config": "^0.4.0"
  }
}
